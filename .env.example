# Polymarket AI Configuration

# Скопіюй цей файл в .env та відредагуй значення

# API Settings
POLYMARKET_API_URL=https://gamma-api.polymarket.com
API_TIMEOUT=10
API_RETRIES=3

# Logging
DEBUG_MODE=false
LOG_LEVEL=INFO
LOG_JSON=false

# Groq API (AI-аналіз/переклад) — безкоштовний ключ: console.groq.com/keys
GROQ_API_KEY=
